{
  "gitBasedApi": {
    "requestDirectory": "requests/",
    "responseDirectory": "responses/",
    "sessionDirectory": "sessions/",
    "workflowTrigger": "push to main branch",
    "processingInterval": "instant (via GitHub Actions)"
  },
  "api": {
    "baseUrl": "https://getwinharris.github.io/bapXconnect/api",
    "version": "v1",
    "defaultModel": "qwen3-omni-30b-a3b-instruct",
    "apiKey": "getwinharris.github.io/bapXconnect/api",
    "authHeader": "X-DashScope-Token"
  },
  "session": {
    "storagePath": "sessions/",
    "format": "json",
    "updateStrategy": "incremental",
    "ttlHours": 24
  },
  "models": {
    "qwen3-omni-30b-a3b-instruct": {
      "path": "https://api-inference.huggingface.co/models/Qwen/Qwen3-Omni-30B-A3B-Instruct",
      "type": "multimodal",
      "capabilities": ["text", "image", "audio", "video", "speech_output", "multilingual"]
    },
    "qwen2.5-omni": {
      "path": "https://api-inference.huggingface.co/models/Qwen/Qwen2.5-Omni-7B",
      "type": "multimodal",
      "capabilities": ["text", "image", "audio", "video", "speech_output"]
    },
    "qwen2.5-coder": {
      "path": "https://api-inference.huggingface.co/models/Qwen/Qwen2.5-Coder-7B-Instruct",
      "type": "coding",
      "capabilities": ["code_generation", "debugging", "explanation", "text"]
    },
    "llama3": {
      "path": "https://api-inference.huggingface.co/models/meta-llama/Meta-Llama-3-8B-Instruct",
      "type": "text",
      "capabilities": ["text_generation", "reasoning", "general_purpose"]
    }
  },
  "githubActions": {
    "workflowFile": ".github/workflows/process_requests.yml",
    "triggerEvent": "push to requests/ directory",
    "processingTimeout": "10 minutes",
    "rateLimit": "based on GitHub Actions limits"
  },
  "apiKeys": {
    "format": "bapX_[app-name]_[random]_[timestamp]",
    "validation": "against admin panel registry",
    "accessLevel": "per_app_isolated"
  }
}