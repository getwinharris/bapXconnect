{
  "api": {
    "endpoint": "https://getwinharris.github.io/bapXconnect/api",
    "version": "v1",
    "model": "qwen2.5-omni",
    "apiKey": "getwinharris.github.io/bapXconnect/api",
    "timeout": 30000,
    "maxRetries": 3,
    "authHeader": "X-DashScope-Token"
  },
  "session": {
    "storagePath": "Client Application Storage (varies by app)/",
    "contextWindowSize": 32768,
    "persistContext": true
  },
  "multimodal": {
    "imageSupport": true,
    "audioSupport": true,
    "videoSupport": true,
    "maxAttachmentSize": "50MB"
  },
  "bapxModel": {
    "path": "https://huggingface.co",
    "quantization": "4bit",
    "gpu": {
      "enabled": false,
      "memoryRequired": "0GB"
    }
  }
}